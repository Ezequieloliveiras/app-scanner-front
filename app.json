{
  "expo": {
    "name": "App Scanner",
    "slug": "app-scanner-front",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "appscanner",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Use a camera para ler codigo de barras e QRCode da nota fiscal."
      }
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.ezequieloliveira.appscannerfront"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Use a camera para ler codigo de barras e QRCode da nota fiscal."
        }
      ]
    ]
  }
}
